# ===========================================
#  .gitignore for JavaScript / Node.js Project
# ===========================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---- Package & Lock Files ----
package.json
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---- Build Output ----
dist/
build/
out/
.next/
.nuxt/
.cache/

# ---- Environment & Secrets ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- OS Generated Files ----
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ---- Editor & IDE Files ----
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace

# ---- Testing ----
coverage/
.nyc_output/
*.lcov

# ---- Temporary Files ----
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig

# ---- Optional / Misc ----
*.tgz
*.zip
*.tar.gz
